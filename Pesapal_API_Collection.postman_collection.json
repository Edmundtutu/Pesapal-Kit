									"mode": "raw",
									"raw": "{\n    \"url\": \"https://example.com/ipn-handler\",\n    \"ipn_notification_type\": \"POST\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/api/URLSetup/RegisterIPN",
									"host": [
