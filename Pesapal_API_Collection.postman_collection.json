		{
			"name": "Orders & Payments",
			"item": [
				{
					"name": "Submit Order Request",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"",
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has order_tracking_id', function () {",
									"    pm.expect(jsonData).to.have.property('order_tracking_id');",
									"});",
									"",
									"pm.test('Response has redirect_url', function () {",
									"    pm.expect(jsonData).to.have.property('redirect_url');",
									"});",
									"",
									"// Save order tracking ID",
									"if (jsonData.order_tracking_id) {",
									"    pm.collectionVariables.set('order_tracking_id', jsonData.order_tracking_id);",
									"    console.log('Order Tracking ID saved: ' + jsonData.order_tracking_id);",
									"}",
									"",
									"// Save merchant reference",
									"if (jsonData.merchant_reference) {",
									"    pm.collectionVariables.set('merchant_reference', jsonData.merchant_reference);",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Generate unique order ID",
									"var orderId = 'ORD-' + Date.now() + '-' + Math.random().toString(36).substring(2, 8).toUpperCase();",
									"pm.collectionVariables.set('order_id', orderId);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{auth_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"id\": \"{{order_id}}\",\n    \"currency\": \"KES\",\n    \"amount\": 100.00,\n    \"description\": \"Test Payment via Postman\",\n    \"callback_url\": \"{{callback_url}}\",\n    \"redirect_mode\": \"PARENT_WINDOW\",\n    \"notification_id\": \"{{ipn_id}}\",\n    \"billing_address\": {\n        \"email_address\": \"test@example.com\",\n        \"phone_number\": \"254700000000\",\n        \"country_code\": \"KE\",\n        \"first_name\": \"John\",\n        \"middle_name\": \"\",\n        \"last_name\": \"Doe\",\n        \"line_1\": \"123 Test Street\",\n        \"line_2\": \"\",\n        \"city\": \"Nairobi\",\n        \"state\": \"\",\n        \"postal_code\": \"\",\n        \"zip_code\": \"\"\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/Transactions/SubmitOrderRequest",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"Transactions",
								"SubmitOrderRequest"
							]
						},
						"description": "Submit a payment order request. Returns a redirect URL for the customer to complete payment.\n\n**Required Fields:**\n- id: Your unique order reference (alphanumeric, max 50 chars)\n- currency: ISO currency code (KES, UGX, TZS, USD)\n- amount: Payment amount\n- description: Order description (max 100 chars)\n- callback_url: URL to redirect after payment\n- notification_id: IPN ID from registration\n- billing_address: Customer details (phone or email required)\n\n**Optional Fields:**\n- redirect_mode: TOP_WINDOW or PARENT_WINDOW\n- cancellation_url: URL if customer cancels\n- branch: Store/branch name"
					},
					"response": [
						{
							"name": "Success Response",
							"originalRequest": {
								"method": "POST",
								"header": [],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"id\": \"ORD-12345\",\n    \"currency\": \"KES\",\n    \"amount\": 100.00,\n    \"description\": \"Test Payment\",\n    \"callback_url\": \"https://example.com/callback\",\n    \"notification_id\": \"84740ab4-3cd9-47da-8a4f-dd1db53494b5\",\n    \"billing_address\": {\n        \"phone_number\": \"254700000000\"\n    }\n}"
								},
								"url": {
									"raw": "{{base_url}}/api/Transactions/SubmitOrderRequest",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"api",
										"Transactions",
										"SubmitOrderRequest"
									]
								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [],
							"body": "{\n    \"order_tracking_id\": \"b945e4af-80a5-4ec1-8706-e03f8332fb04\",\n    \"merchant_reference\": \"ORD-12345\",\n    \"redirect_url\": \"https://cybqa.pesapal.com/pesapaliframe/PesapalIframe3/Index/?OrderTrackingId=b945e4af-80a5-4ec1-8706-e03f8332fb04\",\n    \"error\": null,\n    \"status\": \"200\"\n}"
						}
					]
				},
				{
					"name": "Submit Recurring Order",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"",
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has order_tracking_id', function () {",
									"    pm.expect(jsonData).to.have.property('order_tracking_id');",
									"});",
									"",
									"if (jsonData.order_tracking_id) {",
									"    pm.collectionVariables.set('recurring_order_id', jsonData.order_tracking_id);",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"var orderId = 'SUB-' + Date.now();",
									"pm.collectionVariables.set('subscription_order_id', orderId);",
									"",
									"// Set dates for subscription",
									"var today = new Date();",
									"var endDate = new Date();",
									"endDate.setFullYear(endDate.getFullYear() + 1);",
									"",
									"var formatDate = function(date) {",
									"    var dd = String(date.getDate()).padStart(2, '0');",
									"    var mm = String(date.getMonth() + 1).padStart(2, '0');",
									"    var yyyy = date.getFullYear();",
									"    return dd + '-' + mm + '-' + yyyy;",
									"};",
									"",
									"pm.collectionVariables.set('subscription_start_date', formatDate(today));",
									"pm.collectionVariables.set('subscription_end_date', formatDate(endDate));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{auth_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"id\": \"{{subscription_order_id}}\",\n    \"currency\": \"KES\",\n    \"amount\": 500.00,\n    \"description\": \"Monthly Subscription Payment\",\n    \"callback_url\": \"{{callback_url}}\",\n    \"notification_id\": \"{{ipn_id}}\",\n    \"billing_address\": {\n        \"email_address\": \"subscriber@example.com\",\n        \"phone_number\": \"254700000000\",\n        \"first_name\": \"John\",\n        \"last_name\": \"Subscriber\"\n    },\n    \"account_number\": \"ACCT-{{$randomInt}}\",\n    \"subscription_details\": {\n        \"start_date\": \"{{subscription_start_date}}\",\n        \"end_date\": \"{{subscription_end_date}}\",\n        \"frequency\": \"MONTHLY\"\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/Transactions/SubmitOrderRequest",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"Transactions",
								"SubmitOrderRequest"
							]
						},
						"description": "Submit a recurring/subscription payment order. Customer can set up automated card payments.\n\n**Additional Required Fields:**\n- account_number: Customer account/invoice number\n\n**Optional Subscription Details:**\n- start_date: Format dd-MM-yyyy\n- end_date: Format dd-MM-yyyy\n- frequency: DAILY, WEEKLY, MONTHLY, or YEARLY\n\nNote: Currently only Visa and MasterCard support recurring payments."
					},
					"response": []
				},
				{
					"name": "Get Transaction Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"",
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has status_code', function () {",
									"    pm.expect(jsonData).to.have.property('status_code');",
									"});",
									"",
									"// Save confirmation code if payment completed",
									"if (jsonData.confirmation_code) {",
									"    pm.collectionVariables.set('confirmation_code', jsonData.confirmation_code);",
									"    console.log('Confirmation code saved: ' + jsonData.confirmation_code);",
									"}",
									"",
									"// Log payment status",
									"var statusMap = {",
									"    0: 'INVALID',",
									"    1: 'COMPLETED',",
									"    2: 'FAILED',",
									"    3: 'REVERSED'",
									"};",
									"console.log('Payment Status: ' + (statusMap[jsonData.status_code] || 'UNKNOWN'));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{auth_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/Transactions/GetTransactionStatus?orderTrackingId={{order_tracking_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"Transactions",
								"GetTransactionStatus"
							],
							"query": [
								{
									"key": "orderTrackingId",
									"value": "{{order_tracking_id}}"
								}
							]
						},
						"description": "Check the status of a payment using the OrderTrackingId.\n\n**Status Codes:**\n- 0: INVALID - Transaction not found\n- 1: COMPLETED - Payment successful\n- 2: FAILED - Payment failed\n- 3: REVERSED - Payment reversed/refunded\n\n**Response includes:**\n- payment_method: Method used (Mpesa, Visa, etc.)\n- amount: Amount paid\n- confirmation_code: Payment confirmation code\n- payment_status_description: Status text\n- payment_account: Masked account/phone"
					},
					"response": [
						{
							"name": "Completed Payment",
							"originalRequest": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/api/Transactions/GetTransactionStatus?orderTrackingId=b945e4af-80a5-4ec1-8706-e03f8332fb04",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"api",
										"Transactions",
										"GetTransactionStatus"
									],
									"query": [
										{
											"key": "orderTrackingId",
											"value": "b945e4af-80a5-4ec1-8706-e03f8332fb04"
										}
									]
								}
							},
							"status": "OK",
							"code": 200,
