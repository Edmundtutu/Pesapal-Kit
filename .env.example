# ===========================================
# PESAPAL API CONFIGURATION
# ===========================================

# API Credentials (Get from https://developer.pesapal.com)
PESAPAL_CONSUMER_KEY=your_consumer_key_here
PESAPAL_CONSUMER_SECRET=your_consumer_secret_here

# ===========================================
# ENVIRONMENT SETTINGS
# ===========================================

# Set to 'true' for sandbox/testing, 'false' for production
PESAPAL_SANDBOX=true

# ===========================================
# BASE URLS (Change only if Pesapal updates their URLs)
# ===========================================

# Sandbox/Demo URL
PESAPAL_SANDBOX_URL=https://cybqa.pesapal.com/pesapalv3

# Production/Live URL
PESAPAL_LIVE_URL=https://pay.pesapal.com/v3

# ===========================================
# API ENDPOINTS (Relative paths)
# ===========================================

PESAPAL_AUTH_ENDPOINT=/api/Auth/RequestToken
PESAPAL_REGISTER_IPN_ENDPOINT=/api/URLSetup/RegisterIPN
PESAPAL_LIST_IPN_ENDPOINT=/api/URLSetup/GetIpnList
PESAPAL_SUBMIT_ORDER_ENDPOINT=/api/Transactions/SubmitOrderRequest
PESAPAL_TRANSACTION_STATUS_ENDPOINT=/api/Transactions/GetTransactionStatus
PESAPAL_REFUND_ENDPOINT=/api/Transactions/RefundRequest
PESAPAL_CANCEL_ORDER_ENDPOINT=/api/Transactions/CancelOrder

# ===========================================
# DEFAULT VALUES
# ===========================================

# Default currency (KES, UGX, TZS, USD, etc.)
PESAPAL_CURRENCY=UGX # Change to your preferred currency

# Default redirect mode (TOP_WINDOW or PARENT_WINDOW)
PESAPAL_REDIRECT_MODE=PARENT_WINDOW

# Default IPN notification type (GET or POST)
PESAPAL_IPN_NOTIFICATION_TYPE=POST

# ===========================================
# APPLICATION SETTINGS (Optional)
# ===========================================

# Your application base URL (used for callbacks)
APP_URL=http://localhost/pesapal-to-life  # Change to your actual URL

# Debug mode (set to true for detailed error logging)
APP_DEBUG=true